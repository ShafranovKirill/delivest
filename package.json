{
  "name": "delivest",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for Delivest: NestJS + Vue 3",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint",
    "test": "pnpm -r run test",
    "api:dev": "pnpm --filter @delivest/api dev",
    "web:dev": "pnpm --filter @delivest/web dev"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}